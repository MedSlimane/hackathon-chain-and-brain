{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/analytics/?$",
			"dest": "_render"
		},
		{
			"src": "^/auth/callback/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/farmer/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/health/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/health-risk/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/industry/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/scan-dechets/?$",
			"dest": "_render"
		},
		{
			"src": "^/listings/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/listings/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/marketplace/?$",
			"dest": "_render"
		},
		{
			"src": "^/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/transactions/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/transactions/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}