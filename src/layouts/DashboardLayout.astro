---
import "@/styles/global.css";
import Header from "@/components/common/Header";
import Sidebar from "@/components/common/Sidebar";
import type { UserRole } from "@/lib/database.types";

interface Props {
  title: string;
  subtitle?: string;
  role?: UserRole;
}

const { title, subtitle, role = "admin" } = Astro.props;
const sidebarRole = Astro.locals.profile?.role ?? role;
const wasUnauthorized = Astro.url.searchParams.get("unauthorized") === "1";
const headerUser = {
  name: Astro.locals.profile?.full_name ?? "AgriConnect User",
  email: Astro.locals.user?.email ?? null,
  role: Astro.locals.profile?.role ?? role,
};
const notifications = [
  {
    id: "1",
    title: "New biomass request",
    description: "A buyer viewed your recent listing and requested more details.",
    time: "Now",
  },
  {
    id: "2",
    title: "Traceability check completed",
    description: "Your latest batch hash and integrity validation were stored successfully.",
    time: "2h",
  },
  {
    id: "3",
    title: "Carbon impact updated",
    description: "Your latest transactions improved this month's sustainability score.",
    time: "Today",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | AgriConnect Smart</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-950">
    <div class="flex min-h-screen">
      <Sidebar role={sidebarRole} client:load />
      <main class="min-w-0 flex-1">
        <Header
          title={title}
          subtitle={subtitle}
          user={headerUser}
          notifications={notifications}
          client:load
        />
        <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
          {
            wasUnauthorized ? (
              <div class="mb-5 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
                You were redirected because your account is not allowed to access that area.
              </div>
            ) : null
          }
          <div class="space-y-6">
            <slot />
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
