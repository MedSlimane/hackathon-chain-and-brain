---
import "@/styles/global.css";
import Sidebar from "@/components/common/Sidebar";
import type { UserRole } from "@/lib/database.types";

interface Props {
  title: string;
  subtitle?: string;
  role?: UserRole;
}

const { title, subtitle, role = "admin" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | AgriConnect Smart</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-950">
    <div class="flex min-h-screen">
      <Sidebar role={role} client:load />
      <main class="min-w-0 flex-1">
        <div class="border-b border-slate-200 bg-white px-4 py-4 sm:px-6 lg:px-8">
          <div class="mx-auto max-w-7xl">
            <a href="/" class="text-sm font-medium text-emerald-700 lg:hidden">AgriConnect Smart</a>
            <h1 class="mt-1 text-2xl font-semibold text-slate-950">{title}</h1>
            {subtitle ? <p class="mt-1 text-sm text-slate-500">{subtitle}</p> : null}
          </div>
        </div>
        <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
