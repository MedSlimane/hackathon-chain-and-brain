---
import BlockchainTimeline from "@/components/blockchain/BlockchainTimeline";
import TransactionHash from "@/components/blockchain/TransactionHash";
import HealthRiskCard from "@/components/ai/HealthRiskCard";
import PricePredictionCard from "@/components/ai/PricePredictionCard";
import BiomassCard from "@/components/marketplace/BiomassCard";
import Badge from "@/components/common/Badge";
import MainLayout from "@/layouts/MainLayout.astro";
import { demoBlockchainRecords, demoListings } from "@/lib/sampleData";

export function getStaticPaths() {
  return demoListings.map((listing) => ({ params: { id: listing.id }, props: { listing } }));
}

const { listing } = Astro.props;
const records = demoBlockchainRecords.filter((record) => record.entity_id === listing.id || record.payload?.listing_id === listing.id);
---

<MainLayout title={`${listing.title} | AgriConnect Smart`}>
  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
      <div>
        <a href="/marketplace" class="text-sm font-medium text-emerald-700 hover:text-emerald-800">Back to marketplace</a>
        <h1 class="mt-2 text-3xl font-semibold text-slate-950">{listing.title}</h1>
        <p class="mt-2 max-w-3xl text-slate-600">Detailed marketplace view with AI estimates, environmental impact, and blockchain traceability.</p>
      </div>
      <Badge variant={listing.status === "available" ? "success" : "warning"}>{listing.status}</Badge>
    </div>

    <div class="grid gap-8 lg:grid-cols-[360px_minmax(0,1fr)]">
      <aside class="space-y-5 lg:sticky lg:top-24 lg:self-start">
        <BiomassCard listing={listing} client:load />
        <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="font-semibold text-slate-950">Buyer action</h2>
          <p class="mt-2 text-sm text-slate-600">Request purchase from the industry dashboard and create a traceable transaction hash.</p>
          <div class="mt-4 grid gap-2">
            <a href="/dashboard/industry" class="rounded-md bg-slate-950 px-4 py-2 text-center text-sm font-medium text-white hover:bg-slate-800">Request Purchase</a>
            <a href="/dashboard/farmer" class="rounded-md border border-slate-300 px-4 py-2 text-center text-sm font-medium text-slate-800 hover:bg-slate-50">Farmer dashboard</a>
          </div>
        </section>
      </aside>

      <div class="space-y-6">
        <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">{listing.biomass_type}</p>
              <h2 class="mt-2 text-2xl font-semibold text-slate-950">Listing overview</h2>
              <p class="mt-3 max-w-2xl text-slate-600">{listing.description}</p>
            </div>
          </div>
          <dl class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-md bg-slate-50 p-3"><dt class="text-sm text-slate-500">Quantity</dt><dd class="mt-1 font-semibold text-slate-950">{listing.quantity_kg.toLocaleString()} kg</dd></div>
            <div class="rounded-md bg-slate-50 p-3"><dt class="text-sm text-slate-500">Price</dt><dd class="mt-1 font-semibold text-slate-950">{listing.price_per_kg.toFixed(2)} TND/kg</dd></div>
            <div class="rounded-md bg-slate-50 p-3"><dt class="text-sm text-slate-500">Location</dt><dd class="mt-1 font-semibold text-slate-950">{listing.location}</dd></div>
            <div class="rounded-md bg-slate-50 p-3"><dt class="text-sm text-slate-500">Batch hash</dt><dd class="mt-1"><TransactionHash hash={listing.blockchain_batch_hash} client:load /></dd></div>
          </dl>
        </section>

        <div class="grid gap-6 xl:grid-cols-2">
          <PricePredictionCard listing={listing} client:load />
          <HealthRiskCard pollutionLevel={65} respiratoryRisk={listing.health_risk_reduction_score} carbonSaved={listing.carbon_saved_kg} healthBenefitScore={listing.health_risk_reduction_score} client:load />
        </div>

        <BlockchainTimeline records={records.length ? records : demoBlockchainRecords.slice(0, 3)} client:load />
      </div>
    </div>
  </main>
</MainLayout>
