---
import TransactionHash from "@/components/blockchain/TransactionHash";
import Badge from "@/components/common/Badge";
import MainLayout from "@/layouts/MainLayout.astro";
import { demoListings, demoTransactions } from "@/lib/sampleData";

export function getStaticPaths() {
  return demoTransactions.map((transaction) => ({ params: { id: transaction.id }, props: { transaction } }));
}

const { transaction } = Astro.props;
const listing = demoListings.find((item) => item.id === transaction.listing_id);
---

<MainLayout title="Transaction trace | AgriConnect Smart">
  <main class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
    <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-sky-700">Transaction</p>
          <h1 class="mt-2 text-2xl font-semibold text-slate-950">{listing?.title ?? "Biomass transaction"}</h1>
        </div>
        <Badge variant="info">{transaction.status}</Badge>
      </div>
      <dl class="mt-6 grid gap-4 sm:grid-cols-2">
        <div><dt class="text-sm text-slate-500">Quantity</dt><dd class="font-semibold text-slate-950">{transaction.quantity_kg.toLocaleString()} kg</dd></div>
        <div><dt class="text-sm text-slate-500">Total</dt><dd class="font-semibold text-slate-950">{transaction.total_price.toLocaleString()} TND</dd></div>
        <div><dt class="text-sm text-slate-500">Delivery</dt><dd class="font-semibold text-slate-950">{transaction.delivery_location}</dd></div>
        <div><dt class="text-sm text-slate-500">Hash</dt><dd><TransactionHash hash={transaction.blockchain_transaction_hash} client:load /></dd></div>
      </dl>
    </section>
  </main>
</MainLayout>
